# Copy this to .env.deepline and fill in your values (never commit .env.deepline)

# Deepline — get yours at https://code.deepline.com/dashboard
DEEPLINE_API_KEY=your_deepline_api_key_here

# Smartlead — Settings → API Keys
SMARTLEAD_API_KEY=your_smartlead_api_key_here

# Smartlead campaign to push leads into
SMARTLEAD_CAMPAIGN_ID=your_campaign_id_here

# Clay session cookie (only needed to re-extract the Clay table)
# Copy from any api.clay.com request in Chrome DevTools → Copy as cURL
CLAY_COOKIE='your_clay_session_cookie_here'
CLAY_VERSION='v20260715_071253Z_b6be041e4d'
CLAY_WORKSPACE_ID='11191'
CLAY_WORKBOOK_ID='wb_0tfnx59rTf4ZmYqAUNj'
